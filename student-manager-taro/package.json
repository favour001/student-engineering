{
  "name": "student-manager-taro",
  "version": "0.1.0",
  "private": true,
  "description": "Student manager mobile app migrated from uni-app Vue to Taro React.",
  "scripts": {
    "build:h5": "taro build --type h5",
    "build:weapp": "taro build --type weapp",
    "dev:h5": "taro build --type h5 --watch --port 10086",
    "dev:weapp": "taro build --type weapp --watch",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@babel/runtime": "^7.24.0",
    "@tarojs/components": "4.1.6",
    "@tarojs/helper": "4.1.6",
    "@tarojs/plugin-framework-react": "4.1.6",
    "@tarojs/plugin-platform-h5": "4.1.6",
    "@tarojs/plugin-platform-weapp": "4.1.6",
    "@tarojs/react": "4.1.6",
    "@tarojs/runtime": "4.1.6",
    "@tarojs/shared": "4.1.6",
    "@tarojs/taro": "4.1.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.6.2",
    "@tarojs/cli": "4.1.6",
    "@tarojs/service": "4.1.6",
    "@tarojs/webpack5-runner": "4.1.6",
    "@types/react": "^18.2.79",
    "babel-preset-taro": "4.1.6",
    "postcss": "^8.5.12",
    "react-refresh": "^0.18.0",
    "sass": "^1.75.0",
    "typescript": "^5.4.5",
    "webpack": "5.91.0"
  }
